# Copy this file to .env and fill in real values. Never commit .env.

# Required for the GenAI assistant to answer live questions.
# Without it, /api/chat runs in a safe "degraded" mode and tells
# visitors to ask a steward instead.
ANTHROPIC_API_KEY=

# Optional overrides (defaults shown)
ANTHROPIC_MODEL=claude-sonnet-4-6
FLASK_SECRET_KEY=change-me-to-a-random-value-in-production
FLASK_DEBUG=false
RATE_LIMIT_PER_MINUTE=20
ALLOWED_ORIGINS=http://localhost:5000
MAX_MESSAGE_LENGTH=500
